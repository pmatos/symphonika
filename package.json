{
  "name": "symphonika",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "symphonika": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "fuzz:workflow": "npm run build && jazzer --sync fuzz/workflow-parse.fuzz.mjs -- -max_total_time=30",
    "fuzz:workflow:dry": "npm run build && jazzer --sync --dryRun fuzz/workflow-parse.fuzz.mjs -- -runs=1",
    "lint": "eslint .",
    "mutation": "stryker run",
    "mutation:dry": "stryker run --dryRunOnly",
    "prepare": "npm run build",
    "quality": "npm run lint && npm run typecheck && npm test && npm run build",
    "smoke": "tsx src/cli.ts smoke",
    "smoke:local": "scripts/smoke.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@octokit/rest": "^22.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "hono": "^4.12.19",
    "pino": "^10.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jazzer.js/core": "^4.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.5"
  }
}
